# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# ============================================================
# Jupyter / Notebook
# ============================================================
.ipynb_checkpoints/

# ============================================================
# Environment / Secrets
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# OS / Editor
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ============================================================
# Logs / Temp
# ============================================================
*.log
logs/
tmp/
temp/

# ============================================================
